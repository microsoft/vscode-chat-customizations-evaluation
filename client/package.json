{
  "name": "prompt-lsp-client",
  "displayName": "Prompt LSP",
  "description": "Language Server Protocol implementation for analyzing, validating, and improving AI prompts",
  "version": "0.1.0",
  "publisher": "prompt-lsp",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "prompt",
    "llm",
    "chatgpt",
    "claude",
    "prompt engineering"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "prompt",
        "aliases": [
          "AI Prompt",
          "prompt"
        ],
        "extensions": [
          ".prompt.md",
          ".system.md",
          ".agent.md",
          ".prompt"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "prompt",
        "scopeName": "text.prompt",
        "path": "./syntaxes/prompt.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Prompt LSP",
      "properties": {
        "promptLSP.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable the Prompt LSP extension"
        },
        "promptLSP.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server"
        }
      }
    },
    "commands": [
      {
        "command": "promptLSP.analyzePrompt",
        "title": "Analyze Prompt",
        "category": "Prompt LSP"
      },
      {
        "command": "promptLSP.showTokenCount",
        "title": "Show Token Count",
        "category": "Prompt LSP"
      },
      {
        "command": "promptLSP.clearCache",
        "title": "Clear Analysis Cache",
        "category": "Prompt LSP"
      },
      {
        "command": "promptLSP.fixAllDiagnostics",
        "title": "Fix All Diagnostics",
        "category": "Prompt LSP"
      },
      {
        "command": "promptLSP.fixStaticInstructionStrength",
        "title": "Fix Static: Instruction Strength",
        "category": "Prompt LSP"
      },
      {
        "command": "promptLSP.fixStaticAmbiguity",
        "title": "Fix Static: Ambiguity",
        "category": "Prompt LSP"
      },
      {
        "command": "promptLSP.fixStaticStructure",
        "title": "Fix Static: Structure",
        "category": "Prompt LSP"
      },
      {
        "command": "promptLSP.fixStaticRedundancy",
        "title": "Fix Static: Redundancy",
        "category": "Prompt LSP"
      },
      {
        "command": "promptLSP.fixStaticExamples",
        "title": "Fix Static: Examples",
        "category": "Prompt LSP"
      },
      {
        "command": "promptLSP.fixStaticTokenUsage",
        "title": "Fix Static: Token Usage",
        "category": "Prompt LSP"
      },
      {
        "command": "promptLSP.fixLLMContradictions",
        "title": "Fix LLM: Contradictions",
        "category": "Prompt LSP"
      },
      {
        "command": "promptLSP.fixLLMAmbiguity",
        "title": "Fix LLM: Ambiguity",
        "category": "Prompt LSP"
      },
      {
        "command": "promptLSP.fixLLMPersonaConsistency",
        "title": "Fix LLM: Persona Consistency",
        "category": "Prompt LSP"
      },
      {
        "command": "promptLSP.fixLLMCognitiveLoad",
        "title": "Fix LLM: Cognitive Load",
        "category": "Prompt LSP"
      },
      {
        "command": "promptLSP.fixLLMOutputShape",
        "title": "Fix LLM: Output Shape",
        "category": "Prompt LSP"
      },
      {
        "command": "promptLSP.fixLLMCoverage",
        "title": "Fix LLM: Coverage",
        "category": "Prompt LSP"
      },
      {
        "command": "promptLSP.fixLLMCompositionConflicts",
        "title": "Fix LLM: Composition Conflicts",
        "category": "Prompt LSP"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "^18.x",
    "typescript": "^5.0.0"
  }
}
